[Unit]
Description=Atlas supervised llama.cpp server
After=default.target
StartLimitIntervalSec=120
StartLimitBurst=10

[Service]
Type=simple
ExecStart=%h/.local/bin/node %h/.local/bin/atlas-llama-server.mjs
Restart=on-failure
RestartSec=5
KillMode=control-group
TimeoutStopSec=15
SendSIGKILL=yes
LimitNOFILE=1048576
Environment=ATLAS_CONFIG=%h/.config/atlas-workbench/config.json

[Install]
WantedBy=default.target
